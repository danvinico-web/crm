# ─────────────────────────────────────────────────────────────────────────────
# LeadHub — пример переменных окружения.
# Скопируй в `.env.local` и заполни. НЕ коммить `.env.local`.
#
# Быстрая генерация секретов (macOS/Linux):
#   NEXTAUTH_SECRET  →  openssl rand -base64 32
#   ENCRYPTION_KEY   →  openssl rand -base64 32      (ровно 32 байта после base64-декода)
#   BLIND_INDEX_KEY  →  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# --- База данных ---
# Оставь ПУСТЫМ для локальной разработки — поднимется встроенный in-memory MongoDB
# (mongodb-memory-server) и база засеется демо-данными автоматически.
# Для прод/стейджа укажи строку подключения MongoDB Atlas или своего сервера:
#   MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/leadhub?retryWrites=true&w=majority
MONGODB_URI=

# Имя базы (используется и для in-memory, и для реального сервера)
MONGODB_DB=leadhub

# --- NextAuth (аутентификация: логин + пароль) ---
NEXTAUTH_URL=http://localhost:3000
# Секрет для подписи JWT-сессий. Обязателен в проде.
NEXTAUTH_SECRET=replace_me_with_openssl_rand_base64_32

# --- Шифрование данных at rest (AES-256-GCM) ---
# 32 байта в base64. Используется для API-ключей офисов, секретов вебхуков и PII лидов.
ENCRYPTION_KEY=replace_me_with_openssl_rand_base64_32
# Ключ для «слепых индексов» (HMAC) — позволяет искать/дедуплицировать
# зашифрованные email/телефон, не расшифровывая их.
BLIND_INDEX_KEY=replace_me_with_openssl_rand_base64_32

# --- Стартовый администратор (создаётся при первом сиде) ---
# Главный админ. Может создавать пользователей. Пользователи создают команды.
ADMIN_EMAIL=admin@leadhub.local
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Главный админ

# --- Прочее ---
# Публичный URL приложения (для примеров вебхуков в UI источников/интеграций)
APP_URL=http://localhost:3000
# Пускать автоматический сид демо-данными на пустой базе (dev-удобство)
SEED_ON_EMPTY=true
