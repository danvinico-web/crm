# ─── MVCRM Test Server ───────────────────────────────────────────────────────
# Скопируй в testserver/.env только при необходимости переопределить дефолты.
# Сам сервер env-файлы НЕ читает автоматически — передавай переменные при
# запуске, например:  PORT=4000 ALLOW_ANY_TOKEN=true node server.js

# Порт и хост.
PORT=3001
HOST=127.0.0.1

# Валидные токены аффилиатов (через запятую). Если задано — заменяет дефолтные
# test-token-1 / test-token-2. Каждый токен станет отдельным аффилиатом.
# MVCRM_TOKENS=my-test-token,another-token

# Принимать ЛЮБОЙ непустой токен (аффилиат создаётся на лету). По умолчанию off.
# ALLOW_ANY_TOKEN=false

# Строгая проверка страны (как реальный MVCRM). Выключить для гибких тестов.
# STRICT_COUNTRY=true

# Логировать каждый запрос в консоль.
# LOG_REQUESTS=true
